# =============================================================
#  DLMCare — Variáveis de Ambiente
#  Copiar para .env e preencher com os valores reais.
#  NUNCA commitar o ficheiro .env no repositório.
# =============================================================

# --- Base de Dados ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dlmcare
DB_USER=dlmcare_user
DB_PASSWORD=changeme

# URL completa (usada pelo SQLAlchemy / Alembic)
DATABASE_URL=mysql+pymysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --- Autenticação JWT ---
# Gerar com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_use_a_strong_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480   # 8 horas (1 turno de trabalho)
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Aplicação ---
APP_ENV=development              # development | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
